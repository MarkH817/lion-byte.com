{
  "name": "lion-byte.com",
  "version": "2.0.0",
  "description": "Mark Hernandez's portfolio site",
  "author": "Mark Hernandez <mark@lion-byte.com> (https://www.lion-byte.com)",
  "scripts": {
    "build": "run-s build:* --print-label",
    "build:11ty": "eleventy --quiet",
    "build:webpack": "webpack --config webpack/webpack.prod.js",
    "dev": "run-p dev:* --print-label",
    "dev:11ty": "eleventy --serve",
    "dev:webpack": "webpack --config webpack/webpack.dev.js --watch",
    "format": "npm run prettier && npm run lint -- --fix",
    "lint": "eslint",
    "prettier": "prettier --ignore-path .gitignore --write \"**/*.+(json|yml|yaml|less|css|md)\"",
    "test": "npm run type && node --test",
    "type": "tsc --pretty"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/MarkH817/lion-byte.com.git"
  },
  "keywords": [
    "blog",
    "personal site"
  ],
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "license": "MIT",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "@11ty/eleventy-plugin-rss": "^2.0.4",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.2",
    "@11ty/eleventy-plugin-webc": "^0.11.2",
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-typescript": "^7.28.5",
    "@lionbyte/eslint-config": "^3.0.0",
    "@types/node": "^22.19.12",
    "@types/webpack": "^5.28.5",
    "@types/webpack-bundle-analyzer": "^4.7.0",
    "autoprefixer": "^10.4.27",
    "babel-loader": "^10.0.0",
    "css-loader": "^7.1.4",
    "cssnano": "^7.1.2",
    "date-fns": "^4.1.0",
    "eslint": "^10.0.2",
    "html-minifier-next": "^5.1.1",
    "less": "^4.5.1",
    "less-loader": "^12.3.1",
    "mini-css-extract-plugin": "^2.10.0",
    "npm-run-all2": "^8.0.4",
    "postcss": "^8.5.6",
    "postcss-loader": "^8.2.1",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "webpack": "^5.105.2",
    "webpack-bundle-analyzer": "^5.2.0",
    "webpack-cli": "^6.0.1",
    "webpack-merge": "^6.0.1"
  },
  "dependencies": {
    "core-js": "^3.48.0",
    "modern-normalize": "^3.0.1",
    "prism-themes": "^1.9.0",
    "prismjs": "^1.30.0",
    "regenerator-runtime": "^0.14.1",
    "typeface-nunito": "1.1.13",
    "typeface-open-sans": "1.1.13"
  }
}
